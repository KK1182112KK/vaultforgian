{
  "name": "obsidian-codex-study",
  "version": "0.1.0",
  "private": true,
  "description": "Study-first Obsidian desktop plugin backed by the local Codex login and direct Codex CLI threads.",
  "scripts": {
    "build": "npm run build:bundle && npm run deploy",
    "build:bundle": "node esbuild.config.mjs production",
    "dev": "node esbuild.config.mjs dev",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "deploy": "node scripts/deploy.mjs"
  },
  "devDependencies": {
    "@types/node": "^24.0.14",
    "esbuild": "^0.25.9",
    "obsidian": "^1.8.10",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "pdf-parse": "^2.4.5"
  }
}
